rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Core Security Helpers
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'sahjon87@gmail.com'
      );
    }

    function getAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    function hasAdminDocument() {
      return exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Include the User email from runtime as a super-admin bootstrapped rule
    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'sahjon87@gmail.com' || 
        (hasAdminDocument() && getAdminData().role == 'super-admin')
      );
    }

    // 1. Users Accounts Schema
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // 2. Providers/Workers Accounts Schema
    match /providers/{providerId} {
      allow read: if true;
      allow create: if isOwner(providerId);
      allow update: if isOwner(providerId) || isAdmin();
      allow delete: if isOwner(providerId) || isAdmin();
    }

    // 3. Provider Private KYC Secure Documents
    match /providers/{providerId}/private/kyc {
      allow read: if isOwner(providerId) || isAdmin();
      allow write: if isOwner(providerId) || isAdmin();
    }

    // 4. Shops/Merchants Accounts Schema
    match /shops/{shopId} {
      allow read: if true;
      allow create: if isOwner(shopId);
      allow update: if isOwner(shopId) || isAdmin();
      allow delete: if isOwner(shopId) || isAdmin();
    }

    // 5. Shop Private KYC Secure Documents
    match /shops/{shopId}/private/kyc {
      allow read: if isOwner(shopId) || isAdmin();
      allow write: if isOwner(shopId) || isAdmin();
    }

    // 6. Shop Inventory Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && (
        request.resource.data.shopId == request.auth.uid || 
        request.resource.data.providerId == request.auth.uid
      );
      allow update, delete: if isAdmin() || (isAuthenticated() && (
        resource.data.shopId == request.auth.uid || 
        resource.data.providerId == request.auth.uid
      ));
    }

    // 7. Financial Transactions Bookkeeping
    match /transactions/{transactionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow update, delete: if isAdmin();
    }

    // 8. Financial Withdrawals Requests
    match /withdrawals/{withdrawalId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 9. Service Bookings
    match /bookings/{bookingId} {
      allow read: if isAdmin() || (
        isAuthenticated() && (
          resource.data.customerId == request.auth.uid || 
          resource.data.providerId == request.auth.uid
        )
      );
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAdmin() || (
        isAuthenticated() && (
          resource.data.customerId == request.auth.uid || 
          resource.data.providerId == request.auth.uid
        )
      );
      allow delete: if isAdmin();
    }

    // 10. Shop Orders
    match /orders/{orderId} {
      allow read: if isAdmin() || (
        isAuthenticated() && (
          resource.data.customerId == request.auth.uid || 
          resource.data.shopId == request.auth.uid
        )
      );
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAdmin() || (
        isAuthenticated() && (
          resource.data.customerId == request.auth.uid || 
          resource.data.shopId == request.auth.uid
        )
      );
      allow delete: if isAdmin();
    }

    // 11. Customer Reviews for Providers
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.customerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // 12. Dynamic Chat Sessions
    match /chats/{chatId} {
      allow read, update: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants);
      allow delete: if isAdmin();

      // Support nested messages if any client uses nested chat messages structure
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow create: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants)
                      && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // 13. Root Messages Collection (used directly by ChatPage.tsx)
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      // Let query succeed based on chatId containing the current user's UID
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // 14. Customer Support Tickets
    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.raisedBy == request.auth.uid);
      allow create, write: if request.auth != null;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.raisedBy == request.auth.uid);
      allow delete: if isSuperAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || (
          isAuthenticated() && 
          get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.raisedBy == request.auth.uid
        );
        allow create, write: if request.auth != null;
        allow update, delete: if isAdmin();
      }
    }

    // 15. Canned Helper Responses
    match /canned_responses/{responseId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin() || (isAdmin() && hasAdminDocument() && getAdminData().permissions.canManageSupport == true);
    }

    // 16. App Error Monitor Tracking
    match /app_errors/{document=**} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 17. Platfom Global System Earnings
    match /earnings/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // 18. Centralized System Settings & Promotional Configs
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAdmin();
    }

    // 19. Centralized System Services Categories Dictionary
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSuperAdmin() || isAdmin();
    }

    // 20. Administrators Profiles
    match /admins/{adminId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // 21. Global Broadcast Announcements
    match /broadcast_alerts/{alertId} {
      allow read: if isAuthenticated() || isAdmin();
      allow write: if isAdmin();
    }

    // 22. In-App Notifications
    match /notifications/{notificationId} {
      allow read: if isAdmin() || (
        isAuthenticated() && (
          resource.data.userId == request.auth.uid || 
          (resource.data.userId == 'admin' && isAdmin())
        )
      );
      allow create: if isAuthenticated() || isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
  }
}
